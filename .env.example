# Copy to `.env.local` for local dev. For production, add the same *names* in
# Vercel → Project → Settings → Environment Variables (never commit real keys).

# Supabase — Project Settings → API (https://supabase.com/dashboard)
# DB migrations: docs/BOOKING_SETUP.md
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only. Required for POST /api/book and POST /api/rsvp.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — IANA timezone for /api/book/availability slot grid (default America/New_York)
# BOOKING_TIMEZONE=America/New_York
